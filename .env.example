# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados MySQL
DB_HOST=db
DB_USER=root
DB_PASSWORD=defina_uma_senha_forte
DB_NAME=igreja

# Usadas pelo container do MySQL (docker-compose)
MYSQL_ROOT_PASSWORD=defina_uma_senha_forte
MYSQL_DATABASE=igreja
MYSQL_USER=root
MYSQL_PASSWORD=defina_uma_senha_forte

# Flask — chave usada para assinar a sessão de login
# Gere uma com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Admin inicial — usado apenas na primeira inicialização do app.
# O sistema cria esse usuário automaticamente no banco se ele ainda não existir.
# Depois do primeiro login funcionando, você pode remover estas duas linhas.
ADMIN_USUARIO=admin
ADMIN_SENHA=defina_uma_senha_forte

# Usuário comum inicial — só visualiza, não pode criar/editar/deletar.
# Mesma lógica do admin: criado automaticamente uma única vez.
# Depois do primeiro login funcionando, você pode remover estas duas linhas.
USUARIO_COMUM_USUARIO=membro
USUARIO_COMUM_SENHA=defina_uma_senha_forte
